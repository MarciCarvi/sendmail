<IfModule mod_rewrite.c>
    RewriteEngine on

    # Asset statici: mappa i prefissi noti verso public/ (public/.htaccess li serve come file)
    RewriteRule ^(build|img|favicon|storage)(/.*)?$ public/$1$2 [L,QSA]
    RewriteRule ^(embed\.js|favicon\.ico|robots\.txt)$ public/$1 [L]

    # Tutto il resto → Laravel (inclusi path con /public/ come webhook SNS)
    RewriteRule ^ public/index.php [L,QSA]
</IfModule>
