<IfModule mod_rewrite.c>
    RewriteEngine on

    # Richieste già dentro public/ — servi senza alterare
    RewriteRule ^public/ - [L]

    # Asset statici: mappa i prefissi noti verso public/
    RewriteRule ^(build|img|favicon|storage)(/.*)?$ public/$1$2 [L,QSA]
    RewriteRule ^(embed\.js|favicon\.ico|robots\.txt)$ public/$1 [L]

    # Tutto il resto → Laravel
    RewriteRule ^ public/index.php [L,QSA]
</IfModule>
